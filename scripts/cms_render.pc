// CMS / storefront render policy.
// The host only materializes bytes into arena memory; PicoScript owns the
// Template.Compile + Template.Render serving step and writes the HTTP body bytes.
{{template_bytes}}
{{model_bytes}}
int tmpl = Span.Make({{template_base}}, {{template_len}});
int model = Span.Make({{model_base}}, {{model_len}});
int plan = Template.Compile(tmpl);
int outp = Template.Render(plan, model);
Io.Write(outp);
RETURN;
